{
  "name": "ostinato-desktop-slice",
  "version": "1.4.0",
  "private": true,
  "type": "module",
  "description": "Ostinato Electron/Svelte technical validation slice",
  "main": "dist-electron/electron/main.js",
  "scripts": {
    "controller:build": "cmake -S .. -B ../build-desktop -G Ninja -DCMAKE_BUILD_TYPE=Release -DBUILD_TESTING=ON -DOSTINATO_BUILD_CLIENT=OFF -DOSTINATO_BUILD_QT_TESTS=OFF && cmake --build ../build-desktop --target ostinato-controller drone --parallel",
    "dev": "npm run controller:build && node scripts/dev.mjs",
    "typecheck": "svelte-check --config ./svelte.config.js --tsconfig ./tsconfig.json && tsc -p tsconfig.electron.json --noEmit",
    "lint": "eslint electron shared src tests scripts vite.config.ts playwright.config.ts svelte.config.js",
    "test:unit": "vitest run tests/*.test.ts",
    "test:e2e:direct": "playwright test",
    "test:e2e": "npm run controller:build && xvfb-run -a npm run test:e2e:direct",
    "test": "npm run test:unit && npm run test:e2e",
    "build:renderer": "vite build",
    "build:electron": "tsc -p tsconfig.electron.json && node scripts/write-cjs-package.mjs",
    "build": "npm run typecheck && npm run build:renderer && npm run build:electron",
    "package:linux": "npm run controller:build && npm run build && electron-builder --linux dir",
    "measure:linux": "xvfb-run -a node scripts/measure-linux.mjs"
  },
  "dependencies": {
    "svelte": "5.56.6"
  },
  "devDependencies": {
    "@eslint/js": "9.39.5",
    "@playwright/test": "1.61.1",
    "@sveltejs/vite-plugin-svelte": "5.1.1",
    "@types/node": "22.19.15",
    "electron": "41.5.2",
    "electron-builder": "26.15.3",
    "eslint": "9.39.5",
    "eslint-plugin-svelte": "3.21.0",
    "globals": "16.4.0",
    "svelte-check": "4.7.3",
    "typescript": "5.9.3",
    "typescript-eslint": "8.64.0",
    "vite": "6.4.3",
    "vitest": "3.2.7"
  },
  "overrides": {
    "@noble/hashes": "1.8.0"
  },
  "build": {
    "appId": "org.ostinato.desktop.slice",
    "productName": "Ostinato Desktop",
    "asar": true,
    "npmRebuild": false,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist-electron/**/*",
      "dist-renderer/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../build-desktop/ostinato-controller",
        "to": "controller/ostinato-controller"
      }
    ],
    "linux": {
      "category": "Development",
      "target": [
        "dir"
      ]
    }
  }
}
